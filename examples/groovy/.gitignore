**/.idea/**/kotlinc.xml
**/.idea/**/workspace.xml
**/.idea/**/tasks.xml
**/.idea/**/usage.statistics.xml
**/.idea/**/shelf
**/.idea/**/vcs.xml

# AWS User-specific
**/.idea/**/aws.xml

# Generated files
**/.idea/**/contentModel.xml

# Sensitive or high-churn files
